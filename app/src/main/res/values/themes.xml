<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NetScanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/bg_surface</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_secondary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="materialButtonStyle">@style/Widget.NetScanner.Button</item>
    </style>

    <style name="Theme.NetScanner.Splash" parent="Theme.NetScanner">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Widget.NetScanner.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.NetScanner.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_primary</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.NetScanner.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/bg_secondary</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="navigationIconTint">@color/accent_primary</item>
    </style>
</resources>
